# ====== BACKEND (di Railway/Render — BUKAN Vercel) ======

# ---- Database: Supabase ----
# Ambil dari Supabase Dashboard -> Connect.
# REKOMENDASI: pakai "Session pooler" (port 5432, host *.pooler.supabase.com)
#   -> IPv4-friendly & dukung prepared statement. Paling sedikit masalah.
# Boleh tempel apa adanya dari Supabase (scheme & sslmode otomatis dirapikan kode).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
# Alternatif skala besar: Transaction pooler (port 6543) — kode otomatis matikan
# prepared statement. Pilih salah satu, jangan keduanya.

# ---- Auth ----
JWT_SECRET=ganti-dengan-secret-acak-panjang-min-32-karakter
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# ---- App ----
ENV=production
# Domain Vercel kamu (boleh lebih dari satu, dipisah koma). WAJIB agar login lewat
# browser tidak diblokir CORS.
CORS_ORIGINS=["https://<nama-app>.vercel.app"]

# ---- Seed admin (dibuat oleh: python -m app.seed_asf) ----
# GANTI sebelum seed di produksi — jangan pakai default!
SEED_ADMIN_EMAIL=admin@ananta.local
SEED_ADMIN_PASSWORD=ganti-password-kuat

# ---- Redis: TIDAK DIPERLUKAN (tidak dipakai kode saat ini). Abaikan. ----

# ====== FRONTEND (di Vercel) ======
# Set di Vercel -> Settings -> Environment Variables:
#   API_BASE = https://<url-backend-railway-atau-render>
